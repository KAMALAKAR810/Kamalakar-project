# Core Django
DEBUG=True
SECRET_KEY=replace_with_a_strong_secret_key
ALLOWED_HOSTS=127.0.0.1,localhost
USE_MANIFEST_STATIC_FILES=False
ENABLE_FILE_LOGGING=False

# Email provider: gmail | sendgrid | smtp
EMAIL_PROVIDER=sendgrid

# SendGrid (recommended on free-tier hosting)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_HOST_USER=apikey
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com

# If using Gmail instead, set:
# EMAIL_PROVIDER=gmail
# EMAIL_HOST_USER=your_gmail_address@gmail.com
# EMAIL_HOST_PASSWORD=your_gmail_app_password_here

# Django Email OTP settings
EMAIL_OTP_TTL_SECONDS=300
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60

# Google reCAPTCHA gate
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Telegram bot webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# CSRF trusted origins for hosted domain(s)
# Example: CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://yourapp.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=
